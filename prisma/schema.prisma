// D&D 5e Virtual Tabletop — AI Dungeon Master (multiplayer, room-scoped)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A game room identified by a short shareable code.
model Room {
  id           String   @id @default(cuid())
  code         String   @unique // 6-char uppercase code
  hostName     String
  combatActive Boolean  @default(false)
  round        Int      @default(0)
  location     String   @default("Туманный лес, опушка у древних руин")
  turnIndex    Int      @default(0) // index into the initiative order
  introShown   Boolean  @default(false)
  explorationActorIndex Int @default(0) // whose turn it is during exploration (index into players by createdAt)
  currentMapX  Int      @default(-1) // world-map x coordinate (-1 = no map yet)
  currentMapY  Int      @default(-1) // world-map y coordinate
  timeOfDay    String   @default("day") // dawn | day | dusk | night
  turnCount    Int      @default(0) // exploration turns elapsed (drives day/night cycle)
  weather      String   @default("clear") // clear | rain | fog | storm | snow
  // Crafting stations granted by the DM as the adventure progresses.
  hasAlchemy   Boolean  @default(false)
  hasForge     Boolean  @default(false)
  hasEnchant   Boolean  @default(false)
  // ===== Dungeon generator (Пункт 36) =====
  // Which biome this dungeon uses (catacombs | caves | tower | forest | dungeon).
  dungeonBiome     String   @default("dungeon")
  // Current depth of the dungeon (deeper = more rooms + tougher monsters).
  dungeonDepth     Int      @default(1)
  // True once the boss of the current dungeon depth has been slain.
  dungeonCleared   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  players      Player[]
  monsters     Monster[]
  chatMessages ChatMessage[]
  diceRolls    DiceRoll[]
  scenes       Scene[]
  initiatives  InitiativeEntry[]
  inventory    InventoryItem[]
  conditions   Condition[]
  quests       Quest[]
  mapRooms     MapRoom[]
  npcs         Npc[]
}

/// A player character belonging to a room (a party member).
model Player {
  id               String   @id @default(cuid())
  roomId           String
  room             Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name             String
  charClass        String
  level            Int      @default(1)
  hp               Int
  maxHp            Int
  ac               Int
  str              Int
  dex              Int
  con              Int
  int              Int
  wis              Int
  cha              Int
  proficiencyBonus Int      @default(2)
  gold             Int      @default(10)
  posX             Int      @default(1)
  posY             Int      @default(8)
  color            String
  weaponName       String   @default("Длинный меч")
  weaponNotation   String   @default("1d8+3")
  portraitUrl      String?
  isHost           Boolean  @default(false)
  isAlive          Boolean  @default(true)
  race             String   @default("human")
  raceName         String   @default("Человек")
  background       String   @default("soldier")
  backgroundName   String   @default("Солдат")
  xp               Int      @default(0)
  selectedTalents  String   @default("")
  bonusStr         Int      @default(0)
  bonusDex         Int      @default(0)
  bonusCon         Int      @default(0)
  bonusInt         Int      @default(0)
  bonusWis         Int      @default(0)
  bonusCha         Int      @default(0)
  pendingLevelUp   Boolean  @default(false)
  pendingASI       Boolean  @default(false) // pending Ability Score Improvement pick (levels 5/9/13/17)
  spellSlots       String   @default("") // JSON {"1":2,"2":0,...}
  maxSpellSlots    String   @default("") // JSON {"1":2,"2":0,...}
  hitDice          Int      @default(8)  // hit die size for short-rest healing
  // Equipment slots (store InventoryItem ids). Null = empty.
  eqWeapon         String?
  eqShield         String?
  eqHead           String?
  eqChest          String?
  eqLegs           String?
  eqHands          String?
  eqAccessory1     String?
  eqAccessory2     String?
  // Cumulative AC bonus currently applied from equipped items (delta from base preset AC).
  acBonusApplied   Int      @default(0)
  // JSON of cumulative stat bonuses currently applied from equipped items, e.g. {"str":2,"dex":1}.
  equipStatsApplied String  @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([roomId, name])
}

/// A hostile creature on the grid, scoped to a room.
model Monster {
  id             String   @id @default(cuid())
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name           String
  label          String
  hp             Int      @default(12)
  maxHp          Int      @default(12)
  ac             Int      @default(13)
  damageNotation String   @default("1d6+2")
  attackBonus    Int      @default(3)
  posX           Int      @default(8)
  posY           Int      @default(1)
  color          String   @default("#16a34a")
  description    String   @default("")
  isActive       Boolean  @default(true)
  // ===== Dungeon generator (Пункт 36) =====
  isBoss         Boolean  @default(false)
  specialAbility String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([roomId, name])
}

/// Items carried by players (scoped to room + player name).
model InventoryItem {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playerName  String
  itemName    String
  itemType    String   @default("misc")
  quantity    Int      @default(1)
  description String   @default("")
  /// Equipment slot inferred from name/type (weapon|shield|head|chest|legs|hands|accessory). Null = not equippable.
  equipSlot   String?
  /// AC bonus granted when this item is equipped (armor/shield).
  acBonus     Int      @default(0)
  /// JSON stat bonuses when equipped, e.g. {"str":2,"dex":1}.
  statBonus   String   @default("")
  /// Damage notation for weapons/scrolls (e.g. "1d8+3").
  damageNotation String @default("")
  createdAt   DateTime @default(now())
}

/// Chat log of the table (DM narrative + player messages + system), per room.
model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  role      String   @default("dm") // dm | player | system
  speaker   String   @default("") // player name when role=player
  content   String
  imageUrl  String?
  round     Int      @default(0)
  createdAt DateTime @default(now())
}

/// Persisted dice roll history per room.
model DiceRoll {
  id            String   @id @default(cuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  round         Int      @default(0)
  roller        String   @default("") // who rolled
  label         String
  notation      String
  modifier      Int      @default(0)
  result        Int      @default(0)
  total         Int      @default(0)
  target        Int?
  success       Boolean?
  advantageMode String?  // "advantage" | "disadvantage" | null
  allRolls      String?  // JSON array of all d20 rolls (e.g. "[18, 7]")
  createdAt     DateTime @default(now())
}

/// The currently displayed scene illustration per room.
model Scene {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  imageUrl  String
  prompt    String
  title     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Initiative order entries for a room's combat.
model InitiativeEntry {
  id            String  @id @default(cuid())
  roomId        String
  room          Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  combatantName String
  combatantType String  // "player" | "monster"
  initiative    Int     @default(0)
  order         Int     @default(0) // position in the turn order (0 = first)
  monsterId     String? // link to Monster when type=monster
  isAlive       Boolean @default(true)

  @@unique([roomId, combatantName])
}

/// Active conditions (poisoned, stunned, etc.) applied to players or monsters.
model Condition {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetName  String   // player or monster name
  targetType  String   // "player" | "monster"
  condition   String   // condition id (poisoned, stunned, ...)
  duration    Int      @default(3) // rounds remaining
  source      String   @default("") // who/what applied it
  createdAt   DateTime @default(now())

  @@index([roomId, targetName])
}

/// A quest tracked in the room's quest journal (active/completed/failed).
model Quest {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  status      String   @default("active") // active | completed | failed
  objectives  String   @default("") // comma-separated list
  reward      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomId, status])
}

/// A node in the room's procedurally-generated world map (dungeon rooms).
model MapRoom {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  x           Int
  y           Int
  label       String
  roomType    String   // combat | loot | npc | puzzle | safe | boss | entrance | trap
  discovered  Boolean  @default(false)
  connections String   @default("") // comma-separated "x,y" coords of neighbour rooms
  description String   @default("")
  // ===== Dungeon generator (Пункт 36) =====
  // Secret rooms are hidden until discovered via Perception; shown with a star
  // in the WorldMap UI when revealed.
  secret      Boolean  @default(false)
  // Image-prompt fragment used by /api/game/image for the room's scene art.
  scenePrompt String   @default("")
  // True once populateRoomContent has filled this room (avoids re-spawning
  // monsters / loot when the party revisits).
  populated   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([roomId, x, y])
  @@index([roomId, discovered])
}

/// An NPC living in the room (merchant, questgiver, ally, enemy).
model Npc {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String
  role        String   // merchant | questgiver | ally | enemy
  disposition String   @default("neutral") // friendly | neutral | hostile
  isAlive     Boolean  @default(true)
  location    String   @default("") // where they stand ("У прилавка")
  notes       String   @default("") // free-form DM notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([roomId, name])
  @@index([roomId, role])
  @@index([roomId, isAlive])
}
