// D&D 5e Virtual Tabletop — AI Dungeon Master (multiplayer, room-scoped)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A game room identified by a short shareable code.
model Room {
  id           String   @id @default(cuid())
  code         String   @unique // 6-char uppercase code
  hostName     String
  combatActive Boolean  @default(false)
  round        Int      @default(0)
  location     String   @default("Туманный лес, опушка у древних руин")
  turnIndex    Int      @default(0) // index into the initiative order
  introShown   Boolean  @default(false)
  // dm-context-fix Fix 3: when true, the DM must generate a unique opening
  // narrative on the first player action (instead of using a hardcoded
  // template). Set to true in seed.ts; flipped to false after the intro is
  // generated. Persists across server restarts.
  introNeeded  Boolean  @default(false)
  explorationActorIndex Int @default(0) // whose turn it is during exploration (index into players by createdAt)
  currentMapX  Int      @default(-1) // world-map x coordinate (-1 = no map yet)
  currentMapY  Int      @default(-1) // world-map y coordinate
  timeOfDay    String   @default("day") // dawn | day | dusk | night
  turnCount    Int      @default(0) // exploration turns elapsed (drives day/night cycle)
  weather      String   @default("clear") // clear | rain | fog | storm | snow
  // Crafting stations granted by the DM as the adventure progresses.
  hasAlchemy   Boolean  @default(false)
  hasForge     Boolean  @default(false)
  hasEnchant   Boolean  @default(false)
  /// D&D 5e (V2 A9): Camp supplies count — needed for long rest. 0 = no supplies.
  campSupplies Int      @default(5)
  // ===== Dungeon generator (Пункт 36) =====
  // Which biome this dungeon uses (catacombs | caves | tower | forest | dungeon).
  dungeonBiome     String   @default("dungeon")
  // Current depth of the dungeon (deeper = more rooms + tougher monsters).
  dungeonDepth     Int      @default(1)
  // True once the boss of the current dungeon depth has been slain.
  dungeonCleared   Boolean  @default(false)
  // ===== Account system (auth-restore) =====
  // Optional link to the Account that hosts this room (set when an
  // authenticated user creates a room). Nullable so anonymous play still works.
  hostAccountId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  players      Player[]
  monsters     Monster[]
  chatMessages ChatMessage[]
  diceRolls    DiceRoll[]
  scenes       Scene[]
  initiatives  InitiativeEntry[]
  inventory    InventoryItem[]
  conditions   Condition[]
  quests       Quest[]
  mapRooms     MapRoom[]
  npcs         Npc[]
  traps        Trap[]
  saves        SaveSlot[]
  storyMemories StoryMemory[]
  terrainCells  TerrainCell[]
  containers    Container[]
}

/// A registered user account (auth-restore). Stores a bcrypt password hash;
/// never stores the plaintext password. Identified by a unique username.
model Account {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  saves        SaveSlot[]
  discoveredMonsters DiscoveredMonster[]
}

/// A persistent save slot bound to an Account. Each account has 3 slots
/// (slotNumber 1..3) that remember the room + character so the player can
/// resume a campaign later. Filled slots point at a Room + playerId; empty
/// slots are simply absent rows (the /saves/list route fills in nulls).
model SaveSlot {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  slotNumber  Int
  name        String
  roomId      String?
  room        Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  playerId    String?
  charName    String?
  charClass   String?
  charRace    String?
  charLevel   Int      @default(1)
  lastPlayed  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([accountId, slotNumber])
  @@index([accountId])
}

/// A player character belonging to a room (a party member).
model Player {
  id               String   @id @default(cuid())
  roomId           String
  room             Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name             String
  charClass        String
  level            Int      @default(1)
  hp               Int
  maxHp            Int
  ac               Int
  str              Int
  dex              Int
  con              Int
  int              Int
  wis              Int
  cha              Int
  proficiencyBonus Int      @default(2)
  gold             Int      @default(10)
  posX             Int      @default(2)
  posY             Int      @default(13)
  color            String
  weaponName       String   @default("Длинный меч")
  weaponNotation   String   @default("1d8+3")
  portraitUrl      String?
  isHost           Boolean  @default(false)
  /// D&D 5e (MASTER-PLAN 6.5): true for NPC companions (controlled by AI DM in combat).
  isCompanion      Boolean  @default(false)
  isAlive          Boolean  @default(true)
  race             String   @default("human")
  raceName         String   @default("Человек")
  background       String   @default("soldier")
  backgroundName   String   @default("Солдат")
  backstory        String   @default("")  // player-authored backstory (up to 500 chars)
  xp               Int      @default(0)
  selectedTalents  String   @default("")
  bonusStr         Int      @default(0)
  bonusDex         Int      @default(0)
  bonusCon         Int      @default(0)
  bonusInt         Int      @default(0)
  bonusWis         Int      @default(0)
  bonusCha         Int      @default(0)
  pendingLevelUp   Boolean  @default(false)
  pendingLevelUps  Int      @default(0) // number of talent picks owed (multi-level jumps)
  pendingASI       Boolean  @default(false) // pending Ability Score Improvement pick (levels 5/9/13/17)
  spellSlots       String   @default("") // JSON {"1":2,"2":0,...}
  maxSpellSlots    String   @default("") // JSON {"1":2,"2":0,...}
  hitDice          Int      @default(8)  // hit die size for short-rest healing
  shortRestsUsed   Int      @default(0)  // BG3: track short rests between long rests (max 3)
  // ===== Spellbook (spellbook task) =====
  // Comma-separated list of extra spell IDs the player has learned beyond
  // their class base set (e.g. via reading a "scroll of <spell name>" the DM
  // agent granted through the `learnSpell` plan field). Class base spells are
  // derived in spellbook.ts; this column only stores the *extra* spells.
  spellbookSpells  String   @default("")
  // Equipment slots (store InventoryItem ids). Null = empty.
  eqWeapon         String?
  eqShield         String?
  eqHead           String?
  eqChest          String?
  eqLegs           String?
  eqHands          String?
  eqAccessory1     String?
  eqAccessory2     String?
  // Cumulative AC bonus currently applied from equipped items (delta from base preset AC).
  acBonusApplied   Int      @default(0)
  // JSON of cumulative stat bonuses currently applied from equipped items, e.g. {"str":2,"dex":1}.
  equipStatsApplied String  @default("")
  // ===== BG3/D&D 5e action economy + death saves =====
  // Temporary HP (absorbed before real HP). BG3: shown as a blue overlay.
  tempHp           Int      @default(0)
  // Dying state: when HP reaches 0 the character is dying (not dead).
  // At the start of each turn, roll a death save (d20): 10+ = success,
  // <10 = failure. Nat 20 = 2 successes, nat 1 = 2 failures.
  // 3 successes = stable, 3 failures = dead.
  isDying          Boolean  @default(false)
  deathSaveSuccess Int      @default(0)
  deathSaveFailure Int      @default(0)
  // Action economy pips (reset at the start of each turn).
  // BG3: shown as Action / Bonus Action / Reaction indicators.
  actionUsed       Boolean  @default(false)
  bonusActionUsed  Boolean  @default(false)
  reactionUsed     Boolean  @default(false)
  // Concentration: only ONE concentration spell can be active at a time.
  // Taking damage forces a CON save (DC 10 or half damage, whichever is
  // higher). On failure, concentration breaks and the spell ends.
  concentratingOn  String   @default("")
  // D&D 5e skills & saving throw proficiencies (JSON array of skill/save names).
  // e.g. ["acrobatics","stealth","perception","dex_save","wis_save"]
  // Set at character creation based on class + background.
  skillProficiencies  String   @default("[]")
  saveProficiencies   String   @default("[]")
  // Passive perception = 10 + WIS modifier + proficiency (if proficient).
  // Pre-calculated and stored for DM context.
  passivePerception   Int      @default(10)
  // Spell save DC = 8 + proficiency bonus + casting stat modifier.
  // Pre-calculated and stored for DM context.
  spellSaveDC         Int      @default(12)
  // D&D 5e class resources (JSON). Stores current/max for Rage, Lay on Hands,
  // Ki, Bardic Inspiration, Channel Divinity, Wild Shape, Sorcery Points,
  // Action Surge, Second Wind, Arcane Recovery.
  // e.g. {"rage":{"current":2,"max":2},"layOnHands":{"current":5,"max":5}}
  classResources      String   @default("{}")
  // ===== Movement Points (ОХ) — item #2 =====
  // D&D 5e: speed in feet (default 30 ft = 6 cells). movementUsed = feet
  // spent this turn. dashActive = whether the player has used Dash this turn
  // (doubles available movement). Reset at the start of each turn.
  speed               Int      @default(30)  // feet per turn (30 ft = 6 cells)
  movementUsed        Int      @default(0)   // feet spent this turn
  dashActive          Boolean  @default(false) // Dash action used this turn
  /// D&D 5e Fighting Style (chosen at level 1 for Fighter, Paladin, Ranger).
  /// Values: archery | defense | dueling | great_weapon | two_weapon | protection | none
  fightingStyle       String   @default("")
  /// D&D 5e (MASTER-PLAN-V2 C5): GWM/Sharpshooter -5/+10 toggle (player can turn on/off).
  gwmActive           Boolean  @default(true)
  /// D&D 5e Multiclassing (MASTER-PLAN 4.2): JSON map of class→level, e.g. {"Fighter":3,"Wizard":2}.
  /// Empty = single-class (use charClass + level).
  classLevelsJson     String   @default("")
  /// D&D 5e (MASTER-PLAN 6.2): Z-height level for player tokens (0=ground, 1=ledge, 2=cliff).
  posZ               Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([roomId, name])
}

/// A hostile creature on the grid, scoped to a room.
model Monster {
  id             String   @id @default(cuid())
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name           String
  label          String
  hp             Int      @default(12)
  maxHp          Int      @default(12)
  ac             Int      @default(13)
  damageNotation String   @default("1d6+2")
  attackBonus    Int      @default(3)
  posX           Int      @default(13)
  posY           Int      @default(2)
  /// D&D 5e (MASTER-PLAN 6.2): Z-height level (0=ground, 1=ledge, 2=cliff). Higher gives advantage on ranged attacks.
  posZ           Int      @default(0)
  color          String   @default("#16a34a")
  description    String   @default("")
  isActive       Boolean  @default(true)
  // ===== Dungeon generator (Пункт 36) =====
  isBoss         Boolean  @default(false)
  specialAbility String   @default("")
  // ===== D&D 5e resistances & immunities =====
  // JSON array of damage types the monster resists (half damage).
  // e.g. ["fire","bludgeoning"]
  resistances    String   @default("[]")
  // JSON array of damage types the monster is immune to (no damage).
  // e.g. ["poison","psychic"]
  immunities     String   @default("[]")
  // JSON array of conditions the monster is immune to.
  // e.g. ["poisoned","charmed","frightened"]
  conditionImmunities String @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([roomId, name])
}

/// Items carried by players (scoped to room + player name).
model InventoryItem {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playerName  String
  itemName    String
  itemType    String   @default("misc")
  quantity    Int      @default(1)
  description String   @default("")
  /// Equipment slot inferred from name/type (weapon|shield|head|chest|legs|hands|accessory). Null = not equippable.
  equipSlot   String?
  /// AC bonus granted when this item is equipped (armor/shield).
  acBonus     Int      @default(0)
  /// JSON stat bonuses when equipped, e.g. {"str":2,"dex":1}.
  statBonus   String   @default("")
  /// Damage notation for weapons/scrolls (e.g. "1d8+3").
  damageNotation String @default("")
  /// D&D 5e: true if the player has attuned to this magic item (requires short-rest ritual; max 3 per character).
  attuned        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// Chat log of the table (DM narrative + player messages + system), per room.
model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  role      String   @default("dm") // dm | player | system
  speaker   String   @default("") // player name when role=player
  content   String
  imageUrl  String?
  round     Int      @default(0)
  createdAt DateTime @default(now())
}

/// Persisted dice roll history per room.
model DiceRoll {
  id            String   @id @default(cuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  round         Int      @default(0)
  roller        String   @default("") // who rolled
  label         String
  notation      String
  modifier      Int      @default(0)
  result        Int      @default(0)
  total         Int      @default(0)
  target        Int?
  success       Boolean?
  advantageMode String?  // "advantage" | "disadvantage" | null
  allRolls      String?  // JSON array of all d20 rolls (e.g. "[18, 7]")
  createdAt     DateTime @default(now())
}

/// The currently displayed scene illustration per room.
model Scene {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  imageUrl  String
  prompt    String
  title     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Initiative order entries for a room's combat.
model InitiativeEntry {
  id            String  @id @default(cuid())
  roomId        String
  room          Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  combatantName String
  combatantType String  // "player" | "monster"
  initiative    Int     @default(0)
  order         Int     @default(0) // position in the turn order (0 = first)
  monsterId     String? // link to Monster when type=monster
  isAlive       Boolean @default(true)

  @@unique([roomId, combatantName])
}

/// Active conditions (poisoned, stunned, etc.) applied to players or monsters.
model Condition {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetName  String   // player or monster name
  targetType  String   // "player" | "monster"
  condition   String   // condition id (poisoned, stunned, ...)
  duration    Int      @default(3) // rounds remaining
  source      String   @default("") // who/what applied it
  createdAt   DateTime @default(now())

  @@index([roomId, targetName])
}

/// A quest tracked in the room's quest journal (active/completed/failed).
model Quest {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  status      String   @default("active") // active | completed | failed
  objectives  String   @default("") // comma-separated list
  reward      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomId, status])
}

/// A node in the room's procedurally-generated world map (dungeon rooms).
model MapRoom {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  x           Int
  y           Int
  label       String
  roomType    String   // combat | loot | npc | puzzle | safe | boss | entrance | trap
  discovered  Boolean  @default(false)
  connections String   @default("") // comma-separated "x,y" coords of neighbour rooms
  description String   @default("")
  // ===== Dungeon generator (Пункт 36) =====
  // Secret rooms are hidden until discovered via Perception; shown with a star
  // in the WorldMap UI when revealed.
  secret      Boolean  @default(false)
  // Image-prompt fragment used by /api/game/image for the room's scene art.
  scenePrompt String   @default("")
  // True once populateRoomContent has filled this room (avoids re-spawning
  // monsters / loot when the party revisits).
  populated   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([roomId, x, y])
  @@index([roomId, discovered])
}

/// An NPC living in the room (merchant, questgiver, ally, enemy).
model Npc {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String
  role        String   // merchant | questgiver | ally | enemy
  disposition String   @default("neutral") // friendly | neutral | hostile
  /// D&D 5e (MASTER-PLAN 6.4): NPC loyalty score 0-100. Changes based on player actions.
  /// 0-20=hostile, 21-40=wary, 41-60=neutral, 61-80=friendly, 81-100=devoted.
  loyalty     Int      @default(50)
  isAlive     Boolean  @default(true)
  location    String   @default("") // where they stand ("У прилавка")
  notes       String   @default("") // free-form DM notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([roomId, name])
  @@index([roomId, role])
  @@index([roomId, isAlive])
}

/// A trap placed in a dungeon room (Пункт 36). Triggers when a player steps on
/// its (x, y) cell unless discovered (Perception) or disarmed (Thieves' Tools).
model Trap {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// MapRoom key this trap belongs to ("x,y") — for grouping traps per room.
  mapRoomKey  String   @default("")
  x           Int      @default(0)
  y           Int      @default(0)
  type        String   @default("spike") // spike | pit | arrow | poison | rune | fire
  damage      Int      @default(2)       // number of d6 dice rolled on trigger
  dc          Int      @default(13)      // perception DC to detect + DEX save DC for half
  discovered  Boolean  @default(false)
  disarmed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([roomId, mapRoomKey])
}

/// Persistent story memory — key events, NPC meetings, player choices.
/// The DM agent reads these to maintain narrative continuity.
model StoryMemory {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  type      String   @default("event") // event | npc_met | choice | discovery | combat | reward
  content   String   // what happened (Russian, 1-2 sentences)
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

/// D&D 5e tactical terrain features on the combat grid.
/// Each cell can have one terrain feature that affects combat mechanics:
///   - difficult: difficult terrain (mud/ice/rubble) — movement costs 2x
///   - half_cover: pillar/tree/low wall — +2 AC to creature behind it
///   - full_cover: solid wall/large boulder — blocks line of sight + projectiles
///   - high_ground: elevation — advantage on attacks, enemies have disadvantage
///   - water: shallow water — no special effect but visible
model TerrainCell {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  x         Int
  y         Int
  type      String   // difficult | half_cover | full_cover | high_ground | water
  createdAt DateTime @default(now())

  @@unique([roomId, x, y])
  @@index([roomId])
}

/// Monsters discovered by a player during their adventures. Each account
/// accumulates a bestiary of monsters they've encountered in combat.
/// The BestiaryPanel shows only these discovered monsters (not the full list).
model DiscoveredMonster {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  monsterName String   // Russian name (key into BESTIARY)
  createdAt   DateTime @default(now())

  @@unique([accountId, monsterName])
  @@index([accountId])
}

/// D&D 5e Containers & loot (MASTER-PLAN Phase 3.1): chests, corpses, stashes on the grid.
model Container {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  type        String   // "chest" | "corpse" | "stash" | "barrel"
  posX        Int
  posY        Int
  isOpen      Boolean  @default(false)
  isLocked    Boolean  @default(false)
  lockDC      Int      @default(0)
  gold        Int      @default(0)
  itemsJson   String   @default("[]") // JSON array of { name, type, description, quantity }
  createdAt   DateTime @default(now())

  @@index([roomId])
}
